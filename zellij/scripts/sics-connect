#!/bin/bash

# Copy Ghostty terminfo if needed
if [ "$TERM" = "xterm-ghostty" ]; then
    cache_dir="$HOME/.cache/ghostty-ssh"
    marker="$cache_dir/r2d2"
    if [ ! -f "$marker" ]; then
        echo "Copying Ghostty terminfo to r2d2..."
        if infocmp -x 2>/dev/null | ssh r2d2 tic -x - 2>/dev/null; then
            mkdir -p "$cache_dir"
            touch "$marker"
        fi
    fi
fi

exec ssh r2d2 -t '$HOME/.linuxbrew/bin/zellij attach -c main'
