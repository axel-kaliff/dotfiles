TEMPLATE_DIR := "{{HOME}}/dotfiles/devcontainer/templates"

# Usage: just new-devcontainer <project_name>
new-devcontainer project:
	@echo "Creating new devcontainer project: {{project}}"
	# Create the project folder and its .devcontainer subdirectory
	mkdir -p "{{project}}/.devcontainer"
	# Copy template files into the new project’s .devcontainer folder.
	cp "{{TEMPLATE_DIR}}/devcontainer.json" "{{project}}/.devcontainer/devcontainer.json"
	cp "{{TEMPLATE_DIR}}/Dockerfile" "{{project}}/.devcontainer/Dockerfile"
	@echo "Project '{{project}}' created successfully."

