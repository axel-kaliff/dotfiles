TEMPLATE_DIR := "$HOME/dotfiles/devcontainer/templates"

# Recipe: new-devcontainer
# Usage: just new-devcontainer <project_name>
[no-cd]
new-devcontainer project:
	# Check if the target project directory already exists.
	if [ -d "{{project}}" ]; then \
	  echo "Error: Directory '{{project}}' already exists. Aborting."; \
	  exit 1; \
	fi

	@echo "Creating new devcontainer project: {{project}} in $(pwd)"

	# Create the project folder and .devcontainer subdirectory.
	mkdir -p "{{project}}/.devcontainer"

	# Process devcontainer.json template using envsubst to replace $PROJECT.
	PROJECT="{{project}}" envsubst < "{{TEMPLATE_DIR}}/devcontainer.json" > "{{project}}/.devcontainer/devcontainer.json"

	# Copy the Dockerfile template without changes.
	cp "{{TEMPLATE_DIR}}/Dockerfile" "{{project}}/.devcontainer/Dockerfile"

	@echo "Created .devcontainer in project '{{project}}'."

	cd "{{project}}" && \
	  git init && \
	  echo "# {{project}}" > README.md && \
	  echo "Initialized Git repository and created README.md." && \
	cd - > /dev/null

	@echo "Devcontainer project '{{project}}' created successfully."

